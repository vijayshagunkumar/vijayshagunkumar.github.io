<style>
/* ═══════════════════════════════════════════════
   DESIGN TOKENS
═══════════════════════════════════════════════ */
:root {
  /* palette */
  --navy:       #0c1f3f;
  --navy-deep:  #060f1f;
  --navy-mid:   #132d5a;
  --navy-glow:  rgba(42,94,160,.18);
  --teal:       #0a7a6c;
  --teal-mid:   #0d9a89;
  --teal-light: #12c0ac;
  --teal-pale:  #e7f5f3;
  --gold:       #c49a2e;
  --gold-pale:  #fdf3d8;
  --white:      #ffffff;
  --off:        #f8fafc;
  --surface:    #f1f5f9;
  --border:     #e2e8f2;
  --border-soft:#eef2f8;
  --text:       #1e293b;
  --muted:      #64748b;
  --light:      #94a3b8;

  /* cert brand colors */
  --duke:       #012169;
  --google:     #4285F4;
  --virginia:   #232D4B;
  --oxford:     #002147;
  --oracle-red: #C74634;
  --ibm:        #054ADA;
  --iim:        #8B0000;

  /* shadows — layered for realistic elevation */
  --s0: 0 1px 2px rgba(0,0,0,.04);
  --s1: 0 2px 8px rgba(12,31,63,.06), 0 1px 3px rgba(12,31,63,.04);
  --s2: 0 8px 24px rgba(12,31,63,.09), 0 2px 8px rgba(12,31,63,.05);
  --s3: 0 16px 48px rgba(12,31,63,.12), 0 4px 16px rgba(12,31,63,.06);
  --s4: 0 32px 80px rgba(12,31,63,.16), 0 8px 32px rgba(12,31,63,.08);
  --s-teal: 0 8px 32px rgba(10,122,108,.22);
  --s-gold:  0 8px 24px rgba(196,154,46,.25);

  /* radii */
  --r2:  4px;
  --r4:  8px;
  --r8:  12px;
  --r12: 16px;
  --r16: 20px;
  --r24: 28px;

  /* type */
  --display: 'Playfair Display', Georgia, serif;
  --ui: 'Inter', system-ui, sans-serif;

  /* spacing scale */
  --gap-xs: .5rem;
  --gap-sm: 1rem;
  --gap-md: 1.5rem;
  --gap-lg: 2.5rem;
  --gap-xl: 4rem;
  --section-pad: clamp(3rem, 5vw, 5rem);

  /* motion */
  --ease: cubic-bezier(.4,0,.2,1);
  --spring: cubic-bezier(.16,1,.3,1);
  --nav-h: 68px;
}

/* ═══════════════════════════════════════════════
   RESET & BASE
═══════════════════════════════════════════════ */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; scroll-padding-top:calc(var(--nav-h) + 8px); font-size:17px; }
body {
  font-family: var(--ui);
  background: var(--white);
  color: var(--text);
  line-height: 1.65;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
img { display:block; max-width:100%; }
a { color:inherit; text-decoration:none; }
::-webkit-scrollbar { width:4px; }
::-webkit-scrollbar-track { background:var(--surface); }
::-webkit-scrollbar-thumb { background:var(--navy-mid); border-radius:2px; }

/* ═══════════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════════ */
.wrap { max-width:1180px; margin:0 auto; padding:0 clamp(1.25rem, 4vw, 3rem); }
section { padding:var(--section-pad) 0; }
.divider { height:1px; background:linear-gradient(90deg, transparent, var(--border) 20%, var(--border) 80%, transparent); }

/* ═══════════════════════════════════════════════
   TYPOGRAPHY
═══════════════════════════════════════════════ */
.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: .6rem;
  font-family: var(--ui);
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 1rem;
}
.eyebrow::before { content:''; width:22px; height:2px; background:var(--teal); border-radius:1px; flex-shrink:0; }
.eyebrow.center { justify-content:center; }
.eyebrow.center::before { display:none; }
.eyebrow.center::after { content:''; width:22px; height:2px; background:var(--teal); border-radius:1px; flex-shrink:0; }

h2.section-title {
  font-family: var(--display);
  font-size: clamp(1.6rem, 2.2vw, 2rem);
  font-weight: 700;
  color: var(--navy);
  line-height: 1.1;
  letter-spacing: -.025em;
}
.section-sub {
  color: var(--muted);
  font-size: 1rem;
  max-width: 540px;
  line-height: 1.7;
  margin-top: .6rem;
}
.section-header { text-align:center; margin-bottom:clamp(2rem, 4vw, 3.5rem); }
.section-header .section-sub { margin:0.6rem auto 0; }

/* ═══════════════════════════════════════════════
   BUTTONS
═══════════════════════════════════════════════ */
.btn {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .8rem 1.65rem;
  font-family: var(--ui);
  font-size: .82rem;
  font-weight: 600;
  letter-spacing: .03em;
  border-radius: var(--r4);
  border: none;
  cursor: pointer;
  transition: all .22s var(--ease);
  white-space: nowrap;
  text-decoration: none;
}
.btn-navy { background:var(--navy); color:#fff; box-shadow:0 4px 14px rgba(12,31,63,.3); }
.btn-navy:hover { background:var(--navy-mid); box-shadow:0 6px 22px rgba(12,31,63,.4); transform:translateY(-2px); }
.btn-teal { background:var(--teal); color:#fff; box-shadow:var(--s-teal); }
.btn-teal:hover { background:var(--teal-mid); transform:translateY(-2px); }
.btn-outline { background:transparent; color:var(--navy); border:1.5px solid var(--border); }
.btn-outline:hover { border-color:var(--navy); background:var(--navy); color:#fff; transform:translateY(-2px); }
.btn-ghost { background:rgba(255,255,255,.08); color:rgba(255,255,255,.85); border:1.5px solid rgba(255,255,255,.2); }
.btn-ghost:hover { background:rgba(255,255,255,.15); border-color:rgba(255,255,255,.5); transform:translateY(-2px); }
.btn-white { background:#fff; color:var(--navy); box-shadow:var(--s2); }
.btn-white:hover { background:var(--off); transform:translateY(-2px); box-shadow:var(--s3); }
.btn-outline-w { background:transparent; color:#fff; border:1.5px solid rgba(255,255,255,.35); }
.btn-outline-w:hover { background:rgba(255,255,255,.1); border-color:rgba(255,255,255,.7); transform:translateY(-2px); }

/* ═══════════════════════════════════════════════
   STICKY NAV
═══════════════════════════════════════════════ */
.nav {
  position: sticky;
  top: 0;
  z-index: 200;
  height: var(--nav-h);
  background: rgba(255,255,255,.97);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid var(--border-soft);
  box-shadow: var(--s0);
  transition: box-shadow .3s var(--ease);
}
.nav.scrolled { box-shadow: var(--s2); }
.nav-inner {
  height:100%;
  display:flex;
  align-items:center;
  justify-content:space-between;
  max-width:1180px;
  margin:0 auto;
  padding:0 clamp(1.25rem, 4vw, 3rem);
}
.nav-brand {
  font-family: var(--display);
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--navy);
  letter-spacing: -.01em;
}
.nav-brand span { color:var(--teal); }
.nav-links { display:flex; align-items:center; gap:clamp(.75rem, 1.6vw, 1.8rem); list-style:none; }
.nav-links a {
  font-size: .8rem;
  font-weight: 600;
  color: var(--muted);
  position: relative;
  padding: .25rem 0;
  transition: color .2s;
  letter-spacing: .01em;
}
.nav-links a::after {
  content:'';
  position:absolute;
  bottom:-3px; left:0;
  width:0; height:2px;
  background:var(--teal);
  border-radius:1px;
  transition:width .28s var(--ease);
}
.nav-links a:hover, .nav-links a.active { color:var(--navy); }
.nav-links a:hover::after, .nav-links a.active::after { width:100%; }
.nav-cta-pill {
  padding:.5rem 1.25rem !important;
  background:var(--navy) !important;
  color:#fff !important;
  border-radius:30px !important;
  font-size:.78rem !important;
  letter-spacing:.03em !important;
  transition:background .2s, transform .2s !important;
}
.nav-cta-pill:hover { background:var(--teal) !important; transform:translateY(-1px) !important; }
.nav-cta-pill::after { display:none !important; }
.mob-btn {
  display:none;
  background:none;
  border:1.5px solid var(--border);
  color:var(--navy);
  width:40px; height:40px;
  border-radius:var(--r4);
  cursor:pointer;
  align-items:center;
  justify-content:center;
  font-size:.95rem;
}

/* ═══════════════════════════════════════════════
   HERO — dark navy, editorial
═══════════════════════════════════════════════ */
.hero {
  background: var(--navy-deep);
  position: relative;
  overflow: hidden;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
/* dot matrix texture */
.hero::before {
  content:'';
  position:absolute; inset:0;
  background-image: radial-gradient(circle, rgba(255,255,255,.055) 1px, transparent 1px);
  background-size: 28px 28px;
  pointer-events:none;
  z-index:0;
}
/* warm glow bottom-right */
.hero::after {
  content:'';
  position:absolute;
  bottom:-10%; right:-5%;
  width:55%; height:70%;
  background: radial-gradient(ellipse at center, rgba(10,122,108,.18) 0%, transparent 65%);
  pointer-events:none;
  z-index:0;
}
/* gold top-left glow */
.hero-glow-gold {
  position:absolute;
  top:-5%; left:-5%;
  width:40%; height:50%;
  background: radial-gradient(ellipse at center, rgba(196,154,46,.08) 0%, transparent 65%);
  pointer-events:none;
  z-index:0;
}
/* gold accent top bar */
.hero-bar {
  position:absolute;
  top:0; left:0; right:0;
  height:3px;
  background: linear-gradient(90deg, var(--gold) 0%, var(--teal-light) 50%, transparent 100%);
  z-index:3;
}
.hero-inner {
  position:relative;
  z-index:2;
  padding: clamp(3.5rem,6vw,5.5rem) 0 clamp(3rem,5vw,4.5rem);
}
.hero-layout {
  display:grid;
  grid-template-columns: 1fr auto;
  gap: clamp(2rem, 4vw, 4rem);
  align-items: center;
}
/* LEFT COLUMN */
.hero-left { max-width:700px; }
.hero-pill {
  display: inline-flex;
  align-items: center;
  gap: .55rem;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 30px;
  padding: .32rem .9rem;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: rgba(255,255,255,.75);
  margin-bottom: 1.6rem;
  animation: fadeUp .7s var(--spring) both;
}
.hero-pill::before { content:''; width:7px; height:7px; background:#4ade80; border-radius:50%; animation:pulse 2s ease-in-out infinite; flex-shrink:0; }
.hero-name {
  font-family: var(--display);
  font-size: clamp(2.2rem, 3.8vw, 3.6rem);
  font-weight: 900;
  color: #fff;
  line-height: .9;
  letter-spacing: -.04em;
  margin-bottom: .5rem;
  animation: fadeUp .8s var(--spring) .07s both;
}
.hero-name em {
  font-style: italic;
  font-weight: 300;
  color: var(--teal-light);
  font-size: .48em;
  display: block;
  margin-top: .1em;
}
.hero-role {
  font-size: clamp(.82rem, .95vw, .92rem);
  color: rgba(255,255,255,.55);
  font-weight: 500;
  letter-spacing: .02em;
  margin-bottom: 1.8rem;
  animation: fadeUp .85s var(--spring) .14s both;
  line-height: 1.5;
}
.hero-role strong { color: rgba(255,255,255,.85); font-weight: 600; }
.hero-desc {
  font-size: clamp(.82rem, .9vw, .9rem);
  color: rgba(255,255,255,.6);
  line-height: 1.8;
  max-width: 580px;
  margin-bottom: 2.2rem;
  animation: fadeUp .9s var(--spring) .2s both;
}
.hero-desc strong { color: rgba(255,255,255,.88); font-weight: 600; }
.hero-actions {
  display: flex;
  gap: .75rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
  animation: fadeUp .95s var(--spring) .26s both;
}
/* stats strip */
.hero-stats {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--r8);
  overflow: hidden;
  animation: fadeUp 1s var(--spring) .32s both;
}
.stat {
  padding: .85rem .8rem;
  text-align: center;
  border-right: 1px solid rgba(255,255,255,.07);
  transition: background .25s;
  cursor: default;
}
.stat:last-child { border-right:none; }
.stat:hover { background: rgba(255,255,255,.08); }
.stat-v {
  font-family: var(--display);
  font-size: clamp(1.1rem, 1.4vw, 1.35rem);
  font-weight: 900;
  color: var(--teal-light);
  line-height: 1;
  margin-bottom: .3rem;
}
.stat-l {
  font-size: .6rem;
  font-weight: 600;
  color: rgba(255,255,255,.45);
  letter-spacing: .06em;
  text-transform: uppercase;
  line-height: 1.3;
}
/* RIGHT COLUMN — photo */
.hero-right { flex-shrink:0; animation:fadeIn 1.1s var(--spring) .4s both; width:clamp(180px,15vw,220px); }
.photo-shell {
  position: relative;
  width: 100%;
}
.photo-frame {
  width: 100%;
  aspect-ratio: 3/4;
  border-radius: var(--r16);
  overflow: hidden;
  box-shadow: var(--s4), 0 0 0 1px rgba(255,255,255,.06);
  position: relative;
}
.photo-frame img {
  width:100%; height:100%;
  object-fit:cover;
  object-position: top center;
  display:block;
}
.photo-frame::after { display:none; }
.photo-badge {
  position:absolute;
  bottom:-14px; left:50%;
  transform:translateX(-50%);
  background: var(--teal);
  color: #fff;
  font-size: .62rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  padding: .42rem 1.1rem;
  border-radius: 30px;
  white-space: nowrap;
  box-shadow: var(--s-teal);
  z-index:2;
}
.floating-card {
  position: relative;
  background: rgba(255,255,255,.1);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,.18);
  border-radius: var(--r8);
  padding: .8rem 1.1rem;
  color: #fff;
  z-index:3;
}
.hero-stat-cards { display:flex; gap:.6rem; margin-top:.8rem; }
.fc-card { position:relative; flex:1; min-width:0; }
.fc-num {
  font-family: var(--display);
  font-size: 1.2rem;
  font-weight: 900;
  color: var(--gold);
  line-height: 1;
  margin-bottom: .12rem;
}
.fc-lbl { font-size: .62rem; font-weight: 600; color: rgba(255,255,255,.65); letter-spacing:.06em; text-transform:uppercase; }
/* dot grid deco */
.deco-grid {
  position:absolute;
  width:120px; height:120px;
  background-image:radial-gradient(circle, rgba(255,255,255,.15) 1.5px, transparent 1.5px);
  background-size:12px 12px;
  pointer-events:none;
}
.deco-grid.tl { top:-16px; left:-16px; }

/* ═══════════════════════════════════════════════
   TICKER — scrolling metrics
═══════════════════════════════════════════════ */
.ticker-wrap {
  background: var(--navy);
  border-top: 1px solid rgba(255,255,255,.06);
  padding: .85rem 0;
  overflow: hidden;
}
.ticker-track {
  display: flex;
  gap: 0;
  animation: tickerScroll 40s linear infinite;
  width: max-content;
}
.ticker-item {
  display: flex;
  align-items: center;
  gap: .7rem;
  padding: 0 2.5rem;
  font-size: .78rem;
  font-weight: 600;
  color: rgba(255,255,255,.6);
  letter-spacing: .03em;
  white-space: nowrap;
}
.ticker-item i { color: var(--teal-light); font-size: .7rem; }
.ticker-sep { color: rgba(255,255,255,.2); }
@keyframes tickerScroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

/* ═══════════════════════════════════════════════
   ABOUT SECTION
═══════════════════════════════════════════════ */
.about-grid {
  display: grid;
  grid-template-columns: 1.35fr 1fr;
  gap: clamp(2.5rem, 5vw, 5rem);
  align-items: start;
  margin-top: 2.5rem;
}
.about-text p {
  font-size: clamp(.9rem, 1.2vw, 1rem);
  line-height: 1.85;
  color: var(--muted);
  margin-bottom: 1.1rem;
}
.about-text p:last-child { margin-bottom:0; }
.highlights-box {
  margin-top: 2rem;
  background: linear-gradient(135deg, var(--teal-pale), #eef5ff);
  border: 1px solid rgba(10,122,108,.15);
  border-left: 3px solid var(--teal);
  border-radius: var(--r8);
  padding: 1.4rem 1.6rem;
}
.highlights-box h4 {
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 1rem;
}
.hl-list { list-style:none; display:flex; flex-direction:column; gap:.55rem; }
.hl-list li {
  font-size: .88rem;
  color: var(--text);
  padding-left: 1.3rem;
  position: relative;
  line-height: 1.55;
}
.hl-list li::before {
  content:'';
  position:absolute; left:0; top:8px;
  width:5px; height:5px;
  border-radius:50%;
  background:var(--teal);
}
.about-cards { display:flex; flex-direction:column; gap:1rem; }
.about-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--r8);
  padding: 1.25rem 1.4rem;
  display: flex;
  gap: 1rem;
  align-items: flex-start;
  box-shadow: var(--s1);
  transition: box-shadow .25s var(--ease), transform .25s var(--ease), border-color .25s;
}
.about-card:hover { box-shadow:var(--s3); transform:translateY(-3px); border-color:var(--border); }
.ac-icon {
  width:40px; height:40px; flex-shrink:0;
  background:linear-gradient(135deg, var(--navy), var(--teal));
  border-radius:var(--r4);
  display:flex; align-items:center; justify-content:center;
  color:#fff; font-size:.85rem;
}
.ac-title { font-size:.85rem; font-weight:700; color:var(--navy); margin-bottom:.3rem; }
.ac-body { font-size:.78rem; color:var(--muted); line-height:1.55; }

/* ═══════════════════════════════════════════════
   IMPACT SECTION — prominent, not footer-like
═══════════════════════════════════════════════ */
.impact-section {
  background: var(--white);
  position: relative;
}

.impact-inner { position:relative; z-index:2; }
.impact-banner {
  background: linear-gradient(140deg, var(--navy) 0%, var(--navy-deep) 60%, #0a2240 100%);
  border-radius: var(--r24);
  padding: clamp(2rem, 4vw, 3.5rem);
  position: relative;
  overflow: hidden;
  box-shadow: var(--s4);
}
.impact-banner::before {
  content:'';
  position:absolute; inset:0;
  background-image:radial-gradient(circle, rgba(255,255,255,.04) 1px, transparent 1px);
  background-size:22px 22px;
  pointer-events:none;
}
.impact-banner::after {
  content:'';
  position:absolute; top:-60px; right:-60px;
  width:280px; height:280px;
  background:radial-gradient(circle, rgba(10,122,108,.2) 0%, transparent 65%);
  pointer-events:none;
}
.impact-banner-inner { position:relative; z-index:2; }
.impact-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  margin: 2.8rem 0 2.5rem;
}
.impact-big {
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--r12);
  padding: 1.5rem 1.2rem;
  text-align: center;
  transition: background .25s, transform .25s var(--ease), border-color .25s;
  position: relative;
  overflow: hidden;
}
.impact-big::after {
  content:'';
  position:absolute; top:0; left:0; right:0; height:3px;
  background:linear-gradient(90deg, var(--teal), var(--gold));
  opacity:0; transition:opacity .3s;
}
.impact-big:hover { background:rgba(255,255,255,.1); transform:translateY(-5px); border-color:rgba(10,154,137,.3); }
.impact-big:hover::after { opacity:1; }
.impact-num {
  font-family: var(--display);
  font-size: clamp(1.8rem, 2.8vw, 2.4rem);
  font-weight: 900;
  color: var(--teal-light);
  line-height: 1;
  margin-bottom: .5rem;
}
.impact-label {
  font-size: .75rem;
  font-weight: 600;
  color: rgba(255,255,255,.55);
  letter-spacing: .04em;
  line-height: 1.5;
  text-transform: uppercase;
}
.impact-bullets {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: .75rem;
}
.impact-bullet {
  display: flex;
  align-items: center;
  gap: .8rem;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: var(--r4);
  padding: 1rem 1.2rem;
  transition: background .2s, border-color .2s;
  font-size: .85rem;
  color: rgba(255,255,255,.72);
  line-height: 1.5;
}
.impact-bullet:hover { background:rgba(10,122,108,.18); border-color:rgba(10,154,137,.3); }
.impact-bullet i { color:var(--teal-light); font-size:.75rem; flex-shrink:0; width:18px; text-align:center; }

/* ═══════════════════════════════════════════════
   COMPETENCIES
═══════════════════════════════════════════════ */
.comp-section { background:var(--off); }
.comp-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.5rem;
  margin-top: 2.5rem;
}
.comp-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--r12);
  padding: 1.8rem 1.5rem;
  position: relative;
  overflow: hidden;
  box-shadow: var(--s1);
  transition: box-shadow .28s var(--ease), transform .28s var(--ease), border-color .28s;
}
.comp-card::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:3px;
  background:linear-gradient(90deg, var(--navy), var(--teal));
  transform:scaleX(0);
  transform-origin:left;
  transition:transform .32s var(--ease);
  border-radius:2px 2px 0 0;
}
.comp-card:hover { box-shadow:var(--s3); transform:translateY(-5px); border-color:var(--border); }
.comp-card:hover::before { transform:scaleX(1); }
.comp-icon {
  width:46px; height:46px;
  background:linear-gradient(135deg, rgba(12,31,63,.07), rgba(10,122,108,.09));
  border:1px solid var(--border);
  border-radius:var(--r4);
  display:flex; align-items:center; justify-content:center;
  color:var(--navy); font-size:1rem;
  margin-bottom:1.1rem;
}
.comp-card h3 {
  font-family: var(--ui);
  font-size: .9rem;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: .9rem;
  line-height: 1.25;
}
.comp-list { list-style:none; }
.comp-list li {
  font-size: .8rem;
  color: var(--muted);
  padding: .3rem 0 .3rem .95rem;
  position: relative;
  border-bottom: 1px solid var(--border-soft);
  line-height: 1.45;
}
.comp-list li:last-child { border-bottom:none; }
.comp-list li::before {
  content:'';
  position:absolute; left:0; top:50%;
  transform:translateY(-50%);
  width:4px; height:4px;
  background:var(--teal);
  border-radius:50%;
}

/* ═══════════════════════════════════════════════
   EXPERIENCE TIMELINE
═══════════════════════════════════════════════ */
.exp-section { background:var(--white); }
.timeline {
  position: relative;
  max-width: 880px;
  margin: 3rem auto 0;
}
.timeline::before {
  content:'';
  position:absolute; left:22px; top:12px; bottom:12px;
  width:2px;
  background:linear-gradient(to bottom, var(--navy) 0%, var(--teal) 65%, transparent 100%);
  border-radius:1px;
}
.tl-item {
  position: relative;
  padding: 0 0 3rem 64px;
}
.tl-item:last-child { padding-bottom:0; }
.tl-dot {
  position:absolute; left:13px; top:10px;
  width:20px; height:20px;
  background:var(--white);
  border:3px solid var(--navy);
  border-radius:50%;
  z-index:2;
  transition:border-color .25s, box-shadow .25s;
}
.tl-item:hover .tl-dot { border-color:var(--teal); box-shadow:0 0 0 5px rgba(10,122,108,.12); }
.tl-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--r12);
  padding: 2rem;
  box-shadow: var(--s1);
  transition: box-shadow .28s var(--ease), transform .28s var(--ease);
}
.tl-item:hover .tl-card { box-shadow:var(--s3); transform:translateX(4px); }
.tl-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}
.tl-role {
  font-family: var(--display);
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--navy);
  line-height: 1.2;
  margin-bottom: .22rem;
}
.tl-company { font-size:.82rem; font-weight:700; color:var(--teal); letter-spacing:.03em; }
.tl-loc { font-size:.75rem; color:var(--light); margin-top:.1rem; }
.tl-period {
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  background: var(--surface);
  color: var(--muted);
  font-size: .72rem;
  font-weight: 700;
  padding: .3rem .9rem;
  border-radius: 30px;
  border: 1px solid var(--border);
  white-space: nowrap;
  flex-shrink: 0;
}
.tl-body {
  font-size: .88rem;
  color: var(--muted);
  line-height: 1.75;
  margin-bottom: 1.1rem;
}
.tl-bullets { list-style:none; margin:.5rem 0; }
.tl-bullets li {
  font-size: .85rem;
  color: var(--text);
  padding: .32rem 0 .32rem 1.4rem;
  position: relative;
  line-height: 1.6;
  border-bottom: 1px solid var(--border-soft);
}
.tl-bullets li:last-child { border-bottom:none; }
.tl-bullets li::before {
  content:'';
  position:absolute; left:0; top:11px;
  width:6px; height:6px;
  background:var(--teal-pale);
  border:1.5px solid var(--teal);
  border-radius:50%;
}
.tl-bullets li strong { color:var(--navy); font-weight:700; }
.tl-recog {
  margin-top: 1.2rem;
  background: linear-gradient(135deg, var(--teal-pale), #eef3ff);
  border: 1px solid rgba(10,122,108,.14);
  border-left: 3px solid var(--teal);
  border-radius: var(--r4);
  padding: .85rem 1.1rem;
  font-size: .82rem;
  color: var(--text);
}
.tl-recog-lbl {
  font-size: .63rem;
  font-weight: 700;
  letter-spacing: .13em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: .3rem;
}

/* ═══════════════════════════════════════════════
   PROJECTS
═══════════════════════════════════════════════ */
.projects-section { background:var(--off); }
.proj-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-top: 2.5rem;
}
.proj-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--r12);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: var(--s1);
  transition: box-shadow .28s var(--ease), transform .28s var(--ease), border-color .28s;
}
.proj-card:hover { box-shadow:var(--s4); transform:translateY(-7px); border-color:var(--border); }
.proj-stripe { height:4px; }
.proj-stripe.corp { background:linear-gradient(90deg, var(--navy), var(--teal)); }
.proj-stripe.indie { background:linear-gradient(90deg, var(--gold), #e8b84b); }
.proj-body { padding:1.6rem; flex:1; }
.proj-badge {
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  font-size: .64rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  padding: .24rem .75rem;
  border-radius: 30px;
  margin-bottom: .9rem;
}
.proj-badge.corp { background:rgba(12,31,63,.07); color:var(--navy-mid); border:1px solid rgba(12,31,63,.12); }
.proj-badge.indie { background:var(--gold-pale); color:var(--gold); border:1px solid rgba(196,154,46,.2); }
.proj-card h3 {
  font-family: var(--display);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--navy);
  line-height: 1.3;
  margin-bottom: .55rem;
}
.proj-desc { font-size:.8rem; color:var(--muted); line-height:1.65; margin-bottom:.9rem; }
.proj-metric {
  font-size: .75rem;
  font-weight: 600;
  color: var(--teal);
  background: var(--teal-pale);
  border: 1px solid rgba(10,122,108,.14);
  border-radius: var(--r4);
  padding: .5rem .9rem;
  margin-bottom: 1rem;
  line-height: 1.5;
}
.proj-metric.gold-m { color:var(--gold); background:var(--gold-pale); border-color:rgba(196,154,46,.15); }
.proj-chips { display:flex; flex-wrap:wrap; gap:.35rem; }
.chip {
  font-size: .66rem;
  font-weight: 600;
  padding: .22rem .65rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 30px;
  color: var(--muted);
  transition: background .2s, color .2s;
}
.proj-card:hover .chip { background:var(--off); color:var(--navy); }
.proj-foot {
  padding: 1rem 1.6rem;
  border-top: 1px solid var(--border-soft);
  background: var(--off);
}
.proj-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: .45rem;
  font-size: .76rem;
  font-weight: 700;
  color: var(--navy);
  width:100%;
  background:none;
  border:none;
  cursor:pointer;
  padding:0;
  letter-spacing:.03em;
  transition:color .2s, gap .2s;
}
.proj-action:hover { color:var(--teal); gap:.7rem; }
.proj-action:disabled { opacity:.4; cursor:default; pointer-events:none; }

/* ═══════════════════════════════════════════════
   CERTIFICATIONS — brand colors
═══════════════════════════════════════════════ */
.cert-section { background:var(--white); }
.cert-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.4rem;
  margin-top: 2.5rem;
}
.cert-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--r12);
  padding: 1.5rem;
  position: relative;
  overflow: hidden;
  box-shadow: var(--s1);
  transition: box-shadow .28s var(--ease), transform .28s var(--ease), border-color .28s;
}
.cert-card:hover { box-shadow:var(--s3); transform:translateY(-4px); }
.cert-card::after {
  content:'';
  position:absolute; left:0; top:0;
  width:3px; height:100%;
  opacity:0;
  transition:opacity .28s;
}
.cert-card:hover::after { opacity:1; }
/* individual brand accent colors */
.cert-card[data-brand="duke"]::after    { background:var(--duke); }
.cert-card[data-brand="google"]::after  { background:var(--google); }
.cert-card[data-brand="uva"]::after     { background:var(--virginia); }
.cert-card[data-brand="oxford"]::after  { background:var(--oxford); }
.cert-card[data-brand="oracle"]::after  { background:var(--oracle-red); }
.cert-card[data-brand="ibm"]::after     { background:var(--ibm); }
.cert-card[data-brand="iim"]::after     { background:var(--iim); }
.cert-card:hover[data-brand="duke"]    { border-color:rgba(1,33,105,.25); }
.cert-card:hover[data-brand="google"]  { border-color:rgba(66,133,244,.25); }
.cert-card:hover[data-brand="uva"]     { border-color:rgba(35,45,75,.25); }
.cert-card:hover[data-brand="oxford"]  { border-color:rgba(0,33,71,.25); }
.cert-card:hover[data-brand="oracle"]  { border-color:rgba(199,70,52,.25); }
.cert-card:hover[data-brand="ibm"]     { border-color:rgba(5,74,218,.25); }
.cert-card:hover[data-brand="iim"]     { border-color:rgba(139,0,0,.25); }
.cert-year {
  position:absolute; top:.9rem; right:.9rem;
  font-size:.62rem; font-weight:700; letter-spacing:.07em;
  background:var(--surface); color:var(--light);
  padding:.18rem .58rem; border-radius:30px;
  border:1px solid var(--border);
}
.cert-icon {
  width:46px; height:46px;
  border-radius:var(--r4);
  display:flex; align-items:center; justify-content:center;
  font-size:1.05rem; color:#fff;
  margin-bottom:.9rem;
  box-shadow:var(--s2);
}
.cert-card h3 {
  font-size:.86rem; font-weight:700; color:var(--navy);
  margin-bottom:.22rem; padding-right:4rem; line-height:1.3;
}
.cert-issuer { font-size:.72rem; font-weight:700; color:var(--teal); margin-bottom:.15rem; }
.cert-detail { font-size:.7rem; color:var(--light); margin-bottom:.8rem; }
.cert-link {
  display:inline-flex; align-items:center; gap:.3rem;
  font-size:.68rem; font-weight:700;
  color:var(--muted); letter-spacing:.05em; text-transform:uppercase;
  transition:color .2s;
}
.cert-link:hover { color:var(--navy); }
.cert-wallets {
  display:flex; gap:.75rem; flex-wrap:wrap;
  padding-top:2rem; margin-top:2rem;
  border-top:1px solid var(--border);
}

/* ═══════════════════════════════════════════════
   EDUCATION
═══════════════════════════════════════════════ */
.edu-section { background:var(--off); }
.edu-grid {
  display:grid; grid-template-columns:1fr 1fr;
  gap:1.5rem; max-width:800px; margin:2.5rem auto 0;
}
.edu-card {
  background:var(--white); border:1px solid var(--border);
  border-radius:var(--r12); padding:2rem;
  display:flex; gap:1.2rem; align-items:flex-start;
  box-shadow:var(--s1);
  transition:box-shadow .25s, transform .25s var(--ease);
}
.edu-card:hover { box-shadow:var(--s3); transform:translateY(-3px); }
.edu-icon {
  width:48px; height:48px; flex-shrink:0;
  background:linear-gradient(135deg, var(--navy), var(--navy-mid));
  border-radius:var(--r4);
  display:flex; align-items:center; justify-content:center;
  color:#fff; font-size:1.1rem;
}
.edu-degree { font-family:var(--display); font-size:1.05rem; font-weight:700; color:var(--navy); line-height:1.25; margin-bottom:.28rem; }
.edu-school { font-size:.78rem; font-weight:700; color:var(--teal); margin-bottom:.2rem; }
.edu-meta { font-size:.74rem; color:var(--muted); }

/* ═══════════════════════════════════════════════
   AWARDS
═══════════════════════════════════════════════ */
.awards-section { background:var(--white); }
.awards-grid {
  display:grid; grid-template-columns:repeat(2,1fr);
  gap:1.4rem; margin-top:2.5rem;
}
.award-card {
  background:var(--white); border:1px solid var(--border);
  border-radius:var(--r12); padding:1.8rem;
  display:flex; align-items:flex-start; gap:1.2rem;
  box-shadow:var(--s1);
  transition:box-shadow .25s var(--ease), transform .25s var(--ease), border-color .25s;
}
.award-card:hover { box-shadow:var(--s3); transform:translateY(-3px); border-color:rgba(196,154,46,.3); }
.award-icon {
  width:44px; height:44px; flex-shrink:0;
  background:linear-gradient(135deg, var(--gold-pale), #fce898);
  border:1px solid rgba(196,154,46,.22);
  border-radius:var(--r4);
  display:flex; align-items:center; justify-content:center;
  color:var(--gold); font-size:1.05rem;
}
.award-name { font-size:.9rem; font-weight:700; color:var(--navy); margin-bottom:.35rem; }
.award-desc { font-size:.79rem; color:var(--muted); line-height:1.6; }

/* ═══════════════════════════════════════════════
   CONTACT
═══════════════════════════════════════════════ */
.contact-section { background:var(--off); }
.contact-banner {
  background: linear-gradient(140deg, var(--navy) 0%, var(--navy-deep) 60%, #0a2240 100%);
  border-radius: var(--r24);
  padding: clamp(2.5rem, 5vw, 4rem);
  position: relative;
  overflow: hidden;
  margin-bottom: 2rem;
  box-shadow: var(--s4);
}
.contact-banner::before {
  content:'';
  position:absolute; inset:0;
  background-image:radial-gradient(circle, rgba(255,255,255,.04) 1px, transparent 1px);
  background-size:22px 22px;
}
.contact-banner::after {
  content:'';
  position:absolute; top:-60px; right:-60px;
  width:300px; height:300px;
  background:radial-gradient(circle, rgba(10,122,108,.2) 0%, transparent 65%);
  pointer-events:none;
}
.banner-inner {
  position:relative; z-index:2;
  display:grid; grid-template-columns:1fr auto; gap:2.5rem; align-items:center;
}
.banner-avail {
  display:inline-flex; align-items:center; gap:.45rem;
  font-size:.68rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
  color:rgba(255,255,255,.75);
  background:rgba(255,255,255,.09); border:1px solid rgba(255,255,255,.18);
  padding:.3rem .95rem; border-radius:30px; margin-bottom:.9rem;
}
.banner-avail::before { content:''; width:7px; height:7px; background:#4ade80; border-radius:50%; animation:pulse 2s ease-in-out infinite; }
.banner-inner h3 {
  font-family:var(--display);
  font-size:clamp(1.8rem, 3vw, 2.6rem);
  font-weight:700; color:#fff; line-height:1.15; margin-bottom:.55rem;
}
.banner-inner p { color:rgba(255,255,255,.6); font-size:.95rem; max-width:460px; line-height:1.7; }
.banner-actions { display:flex; flex-direction:column; gap:.75rem; flex-shrink:0; }
.contact-cards { display:grid; grid-template-columns:repeat(3,1fr); gap:1.2rem; }
.contact-card {
  display:flex; align-items:center; gap:1rem;
  background:var(--white); border:1px solid var(--border);
  border-radius:var(--r8); padding:1.3rem;
  color:inherit; box-shadow:var(--s1);
  transition:box-shadow .25s var(--ease), transform .25s var(--ease), border-color .25s;
}
.contact-card:hover { box-shadow:var(--s3); transform:translateY(-3px); border-color:var(--teal); }
.c-icon {
  width:44px; height:44px; flex-shrink:0;
  background:linear-gradient(135deg, var(--navy), var(--teal));
  border-radius:var(--r4);
  display:flex; align-items:center; justify-content:center;
  color:#fff; font-size:.95rem;
}
.c-label { font-size:.64rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--light); margin-bottom:.2rem; }
.c-value { font-size:.86rem; font-weight:600; color:var(--navy); }

/* ═══════════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════════ */
footer {
  background:var(--navy-deep);
  padding:2.2rem 0;
  color:rgba(255,255,255,.5);
}
.foot-inner {
  display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;
}
.foot-brand { font-family:var(--display); font-size:1.1rem; font-weight:700; color:#fff; }
.foot-links { display:flex; gap:1.6rem; }
.foot-links a { font-size:.75rem; font-weight:600; color:rgba(255,255,255,.45); transition:color .2s; }
.foot-links a:hover { color:#fff; }
.foot-copy { font-size:.71rem; }

/* ═══════════════════════════════════════════════
   MODALS
═══════════════════════════════════════════════ */
.modal {
  display:none; position:fixed; inset:0; z-index:400;
  background:rgba(6,15,31,.78);
  backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
  padding:1rem; overflow-y:auto;
}
.modal-box {
  background:var(--white); border-radius:var(--r16);
  max-width:720px; margin:3rem auto;
  overflow:hidden; box-shadow:var(--s4);
  animation:modalIn .32s var(--spring) both;
}
@keyframes modalIn { from{opacity:0;transform:translateY(-20px) scale(.97)} to{opacity:1;transform:none} }
.modal-head {
  background:linear-gradient(135deg, var(--navy), var(--navy-mid));
  padding:2rem 2rem 1.8rem;
  display:flex; justify-content:space-between; align-items:flex-start; gap:1rem;
}
.modal-sub { font-size:.68rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:rgba(255,255,255,.45); margin-bottom:.35rem; }
.modal-head h3 { font-family:var(--display); font-size:1.5rem; font-weight:700; color:#fff; }
.modal-close {
  width:34px; height:34px;
  background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.18);
  border-radius:var(--r4); color:rgba(255,255,255,.7); cursor:pointer;
  display:flex; align-items:center; justify-content:center;
  font-size:1.1rem; transition:all .2s; flex-shrink:0;
}
.modal-close:hover { background:rgba(255,255,255,.2); color:#fff; }
.modal-body { padding:2rem; max-height:60vh; overflow-y:auto; }
