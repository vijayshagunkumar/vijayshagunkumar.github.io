<script>
/* ─── NAV ─── */
const nav = document.getElementById('nav');
const mobBtn = document.getElementById('mobBtn');
const navLinks = document.getElementById('navLinks');

window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 20);
  document.getElementById('scrollTop').style.display = window.scrollY > 600 ? 'flex' : 'none';
}, { passive: true });

mobBtn.addEventListener('click', () => {
  const open = navLinks.classList.toggle('open');
  mobBtn.innerHTML = open ? '<i class="fas fa-times"></i>' : '<i class="fas fa-bars"></i>';
});
navLinks.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
  navLinks.classList.remove('open');
  mobBtn.innerHTML = '<i class="fas fa-bars"></i>';
}));

/* ─── ACTIVE NAV LINK ─── */
const sections = document.querySelectorAll('section[id], header[id]');
const navAs = document.querySelectorAll('.nav-links a');
window.addEventListener('scroll', () => {
  let cur = '';
  sections.forEach(s => { if (window.scrollY >= s.offsetTop - 90) cur = s.id; });
  navAs.forEach(a => a.classList.toggle('active', a.getAttribute('href') === '#' + cur));
}, { passive: true });

/* ─── SCROLL TOP ─── */
document.getElementById('scrollTop').addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

/* ─── REVEAL ON SCROLL ─── */
const revealObs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.07, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

/* ─── STAGGER CHILDREN ─── */
document.querySelectorAll('.comp-grid, .proj-grid, .cert-grid, .awards-grid, .impact-grid, .impact-bullets').forEach(grid => {
  [...grid.children].forEach((child, i) => {
    child.style.transitionDelay = (i * 0.08) + 's';
  });
});

/* ─── BAR ANIMATIONS ─── */
function animateBars(modalId) {
  const modal = document.getElementById(modalId);
  if (!modal) return;
  modal.querySelectorAll('.cs-bar-fill').forEach(bar => {
    const w = bar.dataset.w || 0;
    setTimeout(() => { bar.style.width = w + '%'; }, 100);
  });
}
const origOpen = window.openModal;

/* ─── MODALS ─── */
function openModal(id)  { document.getElementById(id).style.display = 'block'; document.body.style.overflow = 'hidden'; animateBars(id); }
function closeModal(id) { document.getElementById(id).style.display = 'none';  document.body.style.overflow = ''; }
window.addEventListener('click', e => {
  if (e.target.classList.contains('modal')) { e.target.style.display = 'none'; document.body.style.overflow = ''; }
});
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { document.querySelectorAll('.modal').forEach(m => m.style.display = 'none'); document.body.style.overflow = ''; }
});

/* ─── COUNTER ANIMATION on impact numbers ─── */
function animateCounter(el) {
  const raw = el.textContent.trim();
  // Detect suffix: K, M, %, +, $
  const hasK = raw.includes('K');
  const hasM = raw.includes('M');
  const isPercent = raw.includes('%');
  const isPlus = raw.includes('+');
  const hasDollar = raw.startsWith('$');
  const num = parseFloat(raw.replace(/[^0-9.]/g, ''));
  if (isNaN(num)) return;
  const duration = 1600;
  const start = performance.now();
  const frame = ts => {
    const prog = Math.min((ts - start) / duration, 1);
    const eased = 1 - Math.pow(1 - prog, 3);
    const cur = (num * eased).toFixed(num % 1 !== 0 ? 1 : 0);
    const prefix = hasDollar ? '$' : '';
    const suffix = (hasK ? 'K' : '') + (hasM ? 'M' : '') + (isPercent ? '%' : '') + (isPlus ? '+' : '');
    el.textContent = prefix + cur + suffix;
    if (prog < 1) requestAnimationFrame(frame);
  };
  requestAnimationFrame(frame);
}

const numObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.querySelectorAll('.impact-num, .stat-v').forEach(animateCounter);
      numObs.unobserve(e.target);
    }
  });
}, { threshold: 0.3 });
document.querySelectorAll('.impact-grid, .hero-stats').forEach(el => numObs.observe(el));

/* ─── SHOW MORE PROJECTS ─── */
let projectsExpanded = false;
function toggleMoreProjects() {
  projectsExpanded = !projectsExpanded;
  const cards = document.querySelectorAll('.proj-card.hidden-card');
  const btn = document.getElementById('showMoreBtn');
  cards.forEach((card, i) => {
    if (projectsExpanded) {
      setTimeout(() => card.classList.add('shown'), i * 60);
    } else {
      card.classList.remove('shown');
    }
  });
  btn.innerHTML = projectsExpanded
    ? '<i class="fas fa-minus"></i> Show Less'
    : '<i class="fas fa-th"></i> Show All Projects (11 more)';
}


/* ─── RING CHART ANIMATIONS ─── */
const ringObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.querySelectorAll('.ring-fill').forEach(ring => {
        const pct = parseFloat(ring.dataset.pct || 0);
        const circumference = 314;
        const offset = circumference - (pct / 100) * circumference;
        setTimeout(() => { ring.style.strokeDashoffset = offset; }, 200);
      });
      e.target.querySelectorAll('.bm-fill').forEach(bar => {
        const w = bar.dataset.w || 0;
        setTimeout(() => { bar.style.width = w + '%'; }, 200);
      });
      ringObs.unobserve(e.target);
    }
  });
}, { threshold: 0.3 });
document.querySelectorAll('.metric-card, .bar-metric').forEach(el => ringObs.observe(el));

</script>
