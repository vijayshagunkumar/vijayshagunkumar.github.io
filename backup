          <div class="cs-bar-row"><div class="cs-bar-lbl">Cost Reduction</div><div class="cs-bar-track"><div class="cs-bar-fill" data-w="82"></div></div><div class="cs-bar-val">$50K+</div></div>
          <div class="cs-bar-row"><div class="cs-bar-lbl">Txn Coverage</div><div class="cs-bar-track"><div class="cs-bar-fill" data-w="100"></div></div><div class="cs-bar-val">300K+</div></div>
